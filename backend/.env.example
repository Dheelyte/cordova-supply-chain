# ─── Aegis forensic backend · environment ─────────────────────────────────
# Copy to `.env` and adjust. Never commit secrets.

# Service identity
AEGIS_APP_ENV=development
AEGIS_APP_NAME=aegis-forensic
AEGIS_LOG_LEVEL=INFO

# Server
AEGIS_HOST=127.0.0.1
AEGIS_PORT=8000

# CORS — comma-separated origins allowed to talk to the API. The Next dev
# server runs on :3000 by default.
AEGIS_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Storage
AEGIS_UPLOAD_DIR=./uploads
AEGIS_MAX_UPLOAD_BYTES=12582912           # 12 MB

# SSE
AEGIS_SSE_KEEPALIVE_SECONDS=15

# Anthropic — required for build Stage 4 (VLM). Optional for Stage 0.
ANTHROPIC_API_KEY=
